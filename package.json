{
  "name": "budgetBook",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "postinstall": "npx pod-install",
    "prepare": "husky",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start --reset-cache",
    "lint": "eslint .",
    "type-check:watch": "tsc --watch",
    "type-check:all": "tsc",
    "clean": "\\rm -fr ./node_modules && \\rm -fr dist/* && \\rm -fr ios/build ios/Pods && \\rm -fr android/build android/app/build",
    "test": "jest",
    "build:android": "cd android && ./gradlew clean && ./gradlew bundleRelease && cd ..",
    "clean:android": "cd android && ./gradlew clean && cd .."
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native/new-app-screen": "0.84.1",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/material-top-tabs": "^7.4.18",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@shopify/flash-list": "^2.3.0",
    "@tanstack/react-query": "^5.90.21",
    "await-to-js": "^3.0.0",
    "axios": "^1.13.6",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "4.24.0",
    "react-native-vector-icons": "^10.3.0",
    "styled-components": "^6.1.19",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@react-native-community/cli": "20.1.2",
    "@react-native-community/cli-platform-android": "20.1.2",
    "@react-native-community/cli-platform-ios": "20.1.2",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^10.0.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --cache"
    ],
    "**/*.{js,jsx,ts,tsx,json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
